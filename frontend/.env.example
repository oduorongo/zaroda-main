# Frontend environment variables
# Copy to .env.local for local dev, and set in Vercel (Project → Settings → Environment Variables) for production.

# Base URL of the ZARODA backend API (NestJS on Render).
# Local dev:   http://localhost:3000
# Production:  https://<your-render-service>.onrender.com
# IMPORTANT: do NOT include a trailing slash and do NOT append /api/v1 — the app adds /api/v1 itself.
NEXT_PUBLIC_API_URL=http://localhost:3000
