# ════════════════════════════════════════════════
# ZARODA SMS — Backend Environment Variables
# Copy this to .env and fill in your values
# NEVER commit .env to Git
# ════════════════════════════════════════════════

# ── Server
PORT=3000
NODE_ENV=development

# ── Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3001

# ── Database (PostgreSQL)
DATABASE_URL=postgresql://zaroda_app:password@localhost:5432/zaroda_sms
DB_HOST=localhost
DB_PORT=5432
DB_NAME=zaroda_sms
DB_USER=zaroda_app
DB_PASS=password

# ── Redis
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# ── JWT Authentication
JWT_SECRET=change-this-to-a-random-256-bit-string
JWT_REFRESH_SECRET=change-this-to-another-random-256-bit-string
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── Anthropic AI (for CBC document generation)
ANTHROPIC_API_KEY=sk-ant-api03-...

# ── Africa's Talking (SMS)
AT_API_KEY=your-at-api-key
AT_USERNAME=your-at-username
AT_SENDER_ID=ZARODA
AT_ENV=sandbox

# ── M-Pesa Daraja
MPESA_CONSUMER_KEY=your-consumer-key
MPESA_CONSUMER_SECRET=your-consumer-secret
MPESA_SHORTCODE=174379
MPESA_PASSKEY=your-passkey
MPESA_ENV=sandbox
MPESA_CALLBACK_URL=http://localhost:3000/api/v1/finance/mpesa/callback

# ── SMTP Email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your-app-password

# ── VAPID (Web Push)
VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_EMAIL=push@zarodasolutions.app

# ── Firebase (Mobile Push)
FIREBASE_PROJECT_ID=zaroda-sms
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@zaroda-sms.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# ── App
APP_URL=http://localhost:3001
SUPPORT_PHONE=+254781230805
